{
  "name": "polyscan-action",
  "version": "1.0.0",
  "description": "Multi-language SAST orchestrator as a native TypeScript GitHub Action (Semgrep, Bandit, ESLint, SpotBugs) with Quality Gate, SARIF + CycloneDX SBOM and job summary",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "typecheck": "tsc --noEmit",
    "test": "node --test dist-test/ || echo 'no tests'",
    "all": "npm run typecheck && npm run build"
  },
  "keywords": [
    "sast",
    "security",
    "semgrep",
    "bandit",
    "eslint",
    "spotbugs",
    "sarif",
    "sbom",
    "github-action"
  ],
  "author": "Stefan Raisl",
  "license": "MIT",
  "dependencies": {
    "@actions/artifact": "^2.1.11",
    "@actions/core": "^1.11.1",
    "@actions/exec": "^1.1.1",
    "@actions/tool-cache": "^2.0.1"
  },
  "devDependencies": {
    "@types/node": "^24.13.3",
    "@vercel/ncc": "^0.38.3",
    "typescript": "^5.6.3"
  }
}
